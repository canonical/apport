#: ../apport/com.ubuntu.apport.policy.in.h:1
msgid "Collect system information"
msgstr "Sistem məlumatını topla"

#: ../apport/com.ubuntu.apport.policy.in.h:2
msgid ""
"Authentication is required to collect system information for this problem "
"report"
msgstr ""
"Bu problem hesabatı üçün sistem məlumatını toplamaq üçün tanıtma tələb olunur"

#: ../apport/com.ubuntu.apport.policy.in.h:3
msgid "System problem reports"
msgstr "Sistem problemi hesabatları"

#: ../apport/com.ubuntu.apport.policy.in.h:4
msgid "Please enter your password to access problem reports of system programs"
msgstr ""
"Sistem proqramlarının problem hesabatlarına giriş üçün şifrənizi daxil edin"

#: ../apport/ui.py:263
msgid "This package does not seem to be installed correctly"
msgstr "Görünür, bu paket düzgün quraşdırılmayıb"

#: ../apport/ui.py:273
#, python-format
msgid ""
"This does not seem to be an official %s package. Please retry after updating "
"the indexes of available packages, if that does not work then remove related "
"third party packages and try again."
msgstr ""
"Görünür, bu rəsmi %s paketi deyil. Mövcud paketlərin indekslərini "
"yenilədikdən sonra yenidən sınayın, əgər bu işləməsə, əlaqədar üçüncü tərəf "
"paketlərini silin və yenidən cəhd edin."

#: ../apport/ui.py:303
#, python-format
msgid ""
"You have some obsolete package versions installed. Please upgrade the "
"following packages and check if the problem still occurs:\n"
"\n"
"%s"
msgstr ""
"Sizdə bəzi köhnəlmiş paket versiyaları quraşdırılıb. Aşağıdakı paketləri "
"yüksəldin və problemin hələ də davam edib-etmədiyini yoxlayın:\n"
"\n"
"%s"

#: ../apport/ui.py:454
msgid "unknown program"
msgstr "naməlum proqram"

#: ../apport/ui.py:456
#, python-format
msgid "Sorry, the program \"%s\" closed unexpectedly"
msgstr "Bağışlayın, \"%s\" proqramı gözlənilmədən bağlandı"

#: ../apport/ui.py:458
msgid ""
"Your computer does not have enough free memory to automatically analyze the "
"problem and send a report to the developers."
msgstr ""
"Problemi avtomatik təhlil etmək və inkişafçılara hesabat göndərmək üçün "
"kompüterinizdə kifayət qədər boş yaddaş yoxdur."

#: ../apport/ui.py:463 ../apport/ui.py:1872
#, python-format
msgid "Problem in %s"
msgstr "%s daxilində problem"

#: ../apport/ui.py:519 ../apport/ui.py:536 ../apport/ui.py:695
#: ../apport/ui.py:701 ../apport/ui.py:931 ../apport/ui.py:1695
#: ../apport/ui.py:1839 ../apport/ui.py:1845
msgid "Invalid problem report"
msgstr "Yanlış problem hesabatı"

#: ../apport/ui.py:520
msgid "You are not allowed to access this problem report."
msgstr "Bu problem hesabatına daxil olmağa icazəniz yoxdur."

#: ../apport/ui.py:528
msgid "Error"
msgstr "Xəta"

#: ../apport/ui.py:530
msgid "There is not enough disk space available to process this report."
msgstr "Bu hesabatı işləmək üçün diskdə kifayət qədər boş yer yoxdur."

#: ../apport/ui.py:569 ../apport/ui.py:674
msgid "Invalid PID"
msgstr "Yanlış PID"

#: ../apport/ui.py:569
msgid "The specified process ID does not exist."
msgstr "Göstərilən işləm ID-si mövcud deyil."

#: ../apport/ui.py:574
msgid "Not your PID"
msgstr "Sizin PID deyil"

#: ../apport/ui.py:575
msgid "The specified process ID does not belong to you."
msgstr "Göstərilən işləm ID-si sizə məxsus deyil."

#: ../apport/ui.py:632
msgid "No package specified"
msgstr "Paket göstərilməyib"

#: ../apport/ui.py:634
msgid ""
"You need to specify a package or a PID. See --help for more information."
msgstr ""
"Siz paket və ya PID göstərməlisiniz. Daha çox məlumat üçün --help bölməsinə "
"baxın."

#: ../apport/ui.py:661
msgid "Permission denied"
msgstr "İcazə rədd edildi"

#: ../apport/ui.py:663
msgid ""
"The specified process does not belong to you. Please run this program as the "
"process owner or as root."
msgstr ""
"Göstərilən işləm sizə məxsus deyil. Bu proqramı işləm sahibi və ya root "
"olaraq işə salın."

#: ../apport/ui.py:675
msgid "The specified process ID does not belong to a program."
msgstr "Göstərilən işləm ID-si bir proqrama məxsus deyil."

#: ../apport/ui.py:696
#, python-format
msgid "Symptom script %s did not determine an affected package"
msgstr "%s simptom skripti təsirlənmiş paketi müəyyən etmədi"

#: ../apport/ui.py:702
#, python-format
msgid "Package %s does not exist"
msgstr "%s paketi mövcud deyil"

#: ../apport/ui.py:731 ../apport/ui.py:936 ../apport/ui.py:969
#: ../apport/ui.py:976
msgid "Cannot create report"
msgstr "Hesabat yaradıla bilmir"

#: ../apport/ui.py:748 ../apport/ui.py:802 ../apport/ui.py:819
msgid "Updating problem report"
msgstr "Problem hesabatı yenilənir"

#: ../apport/ui.py:750
msgid ""
"You are not the reporter or subscriber of this problem report, or the report "
"is a duplicate or already closed.\n"
"\n"
"Please create a new report using \"apport-bug\"."
msgstr ""
"Siz bu problem hesabatının məruzəçisi və ya abunəçisi deyilsiniz və ya "
"hesabat surətlənib və ya artıq bağlanıb.\n"
"\n"
"\"apport-bug\" istifadə edərək yeni hesabat yaradın."

#: ../apport/ui.py:762
msgid ""
"You are not the reporter of this problem report. It is much easier to mark a "
"bug as a duplicate of another than to move your comments and attachments to "
"a new bug.\n"
"\n"
"Subsequently, we recommend that you file a new bug report using \"apport-"
"bug\" and make a comment in this bug about the one you file.\n"
"\n"
"Do you really want to proceed?"
msgstr ""
"Siz bu problem hesabatının məruzəçisi deyilsiniz. Bir xətanı digərinin "
"surəti olaraq işarələmək rəylərinizi və qoşmalarınızı yeni xətaya "
"köçürməkdən daha asandır.\n"
"\n"
"Buna görə də, \"apport-bug\" istifadə edərək yeni xəta hesabatı yaratmağı və "
"yaratdığınız hesabat haqqında bu xətaya rəy bildirməyi tövsiyə edirik.\n"
"\n"
"Həqiqətən davam etmək istəyirsiniz?"

#: ../apport/ui.py:802 ../apport/ui.py:819
msgid "No additional information collected."
msgstr "Əlavə məlumat toplanmadı."

#: ../apport/ui.py:875
msgid "What kind of problem do you want to report?"
msgstr "Hansı növ problemi bildirmək istəyirsiniz?"

#: ../apport/ui.py:894
msgid "Unknown symptom"
msgstr "Naməlum simptom"

#: ../apport/ui.py:895
#, python-format
msgid "The symptom \"%s\" is not known."
msgstr "\"%s\" simptomu naməlumdur."

#: ../apport/ui.py:915
msgid "No PID specified"
msgstr "PID göstərilməyib"

#: ../apport/ui.py:916
msgid "You need to specify a PID. See --help for more information."
msgstr "Bir PID göstərməlisiniz. Daha çox məlumat üçün --help bölməsinə baxın."

#: ../apport/ui.py:938
msgid ""
"The window option cannot be used on Wayland.\n"
"\n"
"Please find the window's process ID and then run 'ubuntu-bug <process ID>'.\n"
"\n"
"The process ID can be found by running the System Monitor application. In "
"the Processes tab, scroll until you find the correct application. The "
"process ID is the number listed in the ID column."
msgstr ""
"Pəncərə seçimi Wayland üzərində istifadə edilə bilməz.\n"
"\n"
"Pəncərənin işləm ID-sini tapın və sonra 'ubuntu-bug <işləm ID>' işə salın.\n"
"\n"
"İşləm ID-sini Sistem Monitoru tətbiqini işə salaraq tapmaq olar. İşləmlər "
"vərəqində doğru tətbiqi tapana qədər sürüşdürün. İşləm ID-si ID sütununda "
"göstərilən nömrədir."

#: ../apport/ui.py:954
msgid ""
"After closing this message please click on an application window to report a "
"problem about it."
msgstr ""
"Bu ismarıcı bağladıqdan sonra problemi bildirmək üçün tətbiq pəncərəsinə "
"kilikləyin."

#: ../apport/ui.py:970 ../apport/ui.py:977
msgid "xprop failed to determine process ID of the window"
msgstr "xprop pəncərənin işləm ID-sini müəyyən edə bilmədi"

#: ../apport/ui.py:992
#, python-format
msgid "%(prog)s <report number>"
msgstr "%(prog)s <hesabat nömrəsi>"

#: ../apport/ui.py:993
msgid "Specify package name."
msgstr "Paket adını göstərin."

#: ../apport/ui.py:999 ../apport/ui.py:1127
msgid "Add an extra tag to the report. Can be specified multiple times."
msgstr "Hesabata əlavə teq əlavə et. Bir neçə dəfə göstərilə bilər."

#: ../apport/ui.py:1035
#, python-format
msgid ""
"%(prog)s [options] [symptom|pid|package|program path|.apport/.crash file]"
msgstr ""
"%(prog)s [seçimlər] [simptom|pid|paket|proqram yolu|.apport/.crash faylı]"

#: ../apport/ui.py:1046
msgid ""
"Start in bug filing mode. Requires --package and an optional --pid, or just "
"a --pid. If neither is given, display a list of known symptoms. (Implied if "
"a single argument is given.)"
msgstr ""
"Xəta bildirişi rejimində başla. --package və istəyə bağlı --pid və ya sadəcə "
"--pid tələb edir. Əgər heç biri verilməyibsə, məlum simptomların siyahısını "
"göstər. (Tək arqument verilərsə nəzərdə tutulur.)"

#: ../apport/ui.py:1055
msgid "Click a window as a target for filing a problem report."
msgstr "Problem hesabatı yaratmaq üçün hədəf olaraq bir pəncərəyə kilikləyin."

#: ../apport/ui.py:1063
msgid "Start in bug updating mode. Can take an optional --package."
msgstr ""
"Xəta yeniləmə rejimində başla. İstəyə bağlı olaraq --package ala bilər."

#: ../apport/ui.py:1071
msgid ""
"File a bug report about a symptom. (Implied if symptom name is given as only "
"argument.)"
msgstr ""
"Simptom haqqında xəta hesabatı göndər. (Simptom adı tək arqument kimi "
"verilərsə nəzərdə tutulur.)"

#: ../apport/ui.py:1080
msgid ""
"Specify package name in --file-bug mode. This is optional if a --pid is "
"specified. (Implied if package name is given as only argument.)"
msgstr ""
"--file-bug rejimində paket adını göstərin. Bu, --pid göstərildiyi halda "
"istəyə bağlıdır. (Paket adı tək arqument kimi verilərsə nəzərdə tutulur.)"

#: ../apport/ui.py:1091
msgid ""
"Specify a running program in --file-bug mode. If this is specified, the bug "
"report will contain more information.  (Implied if pid is given as only "
"argument.)"
msgstr ""
"--file-bug rejimində işləyən proqramı göstərin. Bu göstərilərsə, xəta "
"hesabatı daha çox məlumat ehtiva edəcək. (Pid tək arqument kimi verilərsə "
"nəzərdə tutulur.)"

#: ../apport/ui.py:1099
msgid "The provided pid is a hanging application."
msgstr "Təqdim edilmiş pid donmuş tətbiqdir."

#: ../apport/ui.py:1107
#, python-format
msgid ""
"Report the crash from given .apport or .crash file instead of the pending "
"ones in %s. (Implied if file is given as only argument.)"
msgstr ""
"Qəzanı %s daxilində gözləyənlərin əvəzinə verilmiş .apport və ya .crash "
"faylından bildir. (Fayl tək arqument kimi verilərsə nəzərdə tutulur.)"

#: ../apport/ui.py:1117
msgid ""
"In bug filing mode, save the collected information into a file instead of "
"reporting it. This file can then be reported later on from a different "
"machine."
msgstr ""
"Xəta bildirişi rejimində toplanmış məlumatı hesabat vermək əvəzinə faylda "
"yadda saxla. Bu fayl daha sonra fərqli cihazdan bildirilə bilər."

#: ../apport/ui.py:1133
msgid "Print the Apport version number."
msgstr "Apport versiya nömrəsini çap et."

#: ../apport/ui.py:1292
msgid ""
"This will launch apport-retrace in a terminal window to examine the crash."
msgstr ""
"Bu, qəzanı yoxlamaq üçün terminal pəncərəsində apport-retrace başladacaq."

#: ../apport/ui.py:1296
msgid "Run gdb session"
msgstr "gdb seansını işə sal"

#: ../apport/ui.py:1297
msgid "Run gdb session without downloading debug symbols"
msgstr "debug simvollarını endirmədən gdb seansını işə sal"

#. TRANSLATORS: %s contains the crash report file name
#: ../apport/ui.py:1299
#, python-format
msgid "Update %s with fully symbolic stack trace"
msgstr "%s tam simvolik yığın izi ilə yenilə"

#: ../apport/ui.py:1353
msgid ""
"Saving crash reporting state failed. Can't set auto or never reporting mode."
msgstr ""
"Qəza hesabatı vəziyyətini yadda saxlamaq mümkün olmadı. Avtomatik və ya heç "
"vaxt hesabat vermə rejimini təyin etmək olmur."

#: ../apport/ui.py:1357
msgid "Can't remember send report status settings"
msgstr "Hesabat göndərmə vəziyyəti tənzimləmələrini xatırlamaq olmur"

#: ../apport/ui.py:1439 ../apport/ui.py:1452
msgid ""
"This problem report applies to a program which is not installed any more."
msgstr "Bu problem hesabatı artıq quraşdırılmayan proqrama aiddir."

#: ../apport/ui.py:1472
#, python-format
msgid ""
"The problem happened with the program %s which changed since the crash "
"occurred."
msgstr "Problem qəza baş verdikdən sonra dəyişilmiş %s proqramı ilə baş verdi."

#. can happen with broken core dumps
#. can happen with broken gz values
#: ../apport/ui.py:1531 ../apport/ui.py:1643 ../apport/ui.py:1843
msgid "This problem report is damaged and cannot be processed."
msgstr "Bu problem hesabatı zədələnmişdir və işlənə bilməz."

#: ../apport/ui.py:1537
msgid "This report is about a package that is not installed."
msgstr "Bu hesabat quraşdırılmamış paket haqqındadır."

#: ../apport/ui.py:1544
msgid "An error occurred while attempting to process this problem report:"
msgstr "Bu problem hesabatını işləməyə cəhd edərkən xəta baş verdi:"

#: ../apport/ui.py:1561
msgid ""
"You have two versions of this application installed, which one do you want "
"to report a bug against?"
msgstr ""
"Bu tətbiqin iki versiyası quraşdırılıb, hansı biri üçün xəta hesabatı vermək "
"istəyirsiniz?"

#: ../apport/ui.py:1566
#, python-format
msgid "%s snap"
msgstr "%s snap"

#: ../apport/ui.py:1567
#, python-format
msgid "%s deb package"
msgstr "%s deb paketi"

#: ../apport/ui.py:1605
#, python-format
msgid "%s is provided by a snap published by %s. Contact them via %s for help."
msgstr ""
"%s, %s tərəfindən yayımlanan snap tərəfindən təqdim edilmişdir. Kömək üçün "
"%s vasitəsilə onlarla əlaqə saxlayın."

#: ../apport/ui.py:1610
#, python-format
msgid ""
"%s is provided by a snap published by %s. No contact address has been "
"provided; visit the forum at https://forum.snapcraft.io/ for help."
msgstr ""
"%s, %s tərəfindən yayımlanan snap tərəfindən təqdim edilmişdir. Heç bir "
"əlaqə ünvanı təqdim edilməyib; kömək üçün https://forum.snapcraft.io/ "
"ünvanındakı foruma daxil olun."

#: ../apport/ui.py:1696
msgid "Could not determine the package or source package name."
msgstr "Paketi və ya mənbə paketi adını müəyyən etmək mümkün olmadı."

#: ../apport/ui.py:1727
msgid "Unable to start web browser"
msgstr "Veb brauzeri başlatmaq mümkün olmadı"

#: ../apport/ui.py:1728
#, python-format
msgid "Unable to start web browser to open %s."
msgstr "%s açmaq üçün veb brauzeri başlatmaq mümkün olmadı."

#: ../apport/ui.py:1801
msgid ""
"Cannot connect to crash database, please check your Internet connection."
msgstr "Qəza bazasına bağlanmaq olmur, internet bağlantınızı yoxlayın."

#: ../apport/ui.py:1804
msgid "Network problem"
msgstr "Şəbəkə problemi"

#: ../apport/ui.py:1830
msgid "Memory exhaustion"
msgstr "Yaddaş tükənməsi"

#: ../apport/ui.py:1832
msgid "Your system does not have enough memory to process this crash report."
msgstr ""
"Sisteminizdə bu qəza hesabatını işləmək üçün kifayət qədər yaddaş yoxdur."

#: ../apport/ui.py:1877
#, python-format
msgid ""
"The problem cannot be reported:\n"
"\n"
"%s"
msgstr ""
"Problem bildirilə bilmir:\n"
"\n"
"%s"

#: ../apport/ui.py:1931 ../apport/ui.py:1943
msgid "Problem already known"
msgstr "Problem artıq məlumdur"

#: ../apport/ui.py:1933
msgid ""
"This problem was already reported in the bug report displayed in the web "
"browser. Please check if you can add any further information that might be "
"helpful for the developers."
msgstr ""
"Bu problem veb brauzerdə göstərilən xəta hesabatında artıq bildirilib. "
"İnkişafçılar üçün faydalı ola biləcək əlavə məlumat əlavə edə biləcəyinizi "
"yoxlayın."

#: ../apport/ui.py:1944
msgid "This problem was already reported to developers. Thank you!"
msgstr "Bu problem artıq inkişafçılara bildirilib. Təşəkkür edirik!"

#: ../bin/apport-cli.py:91
msgid "Press any key to continue..."
msgstr "Davam etmək üçün istənilən düyməni sıxın..."

#: ../bin/apport-cli.py:98
msgid "What would you like to do? Your options are:"
msgstr "Nə etmək istərdiniz? Seçimləriniz bunlardır:"

#: ../bin/apport-cli.py:111
#, python-format
msgid "Please choose (%s):"
msgstr "Seçin (%s):"

#: ../bin/apport-cli.py:171
#, python-format
msgid "(%i bytes)"
msgstr "(%i bayt)"

#: ../bin/apport-cli.py:173 ../gtk/apport-gtk.py:136 ../kde/apport-kde.py:422
msgid "(binary data)"
msgstr "(ikili məlumat)"

#: ../bin/apport-cli.py:213 ../gtk/apport-gtk.py:176 ../gtk/apport-gtk.ui.h:6
#: ../kde/apport-kde.py:210
msgid "Send problem report to the developers?"
msgstr "Problem hesabatı inkişafçılara göndərilsin?"

#: ../bin/apport-cli.py:215
msgid ""
"After the problem report has been sent, please fill out the form in the\n"
"automatically opened web browser."
msgstr ""
"Problem hesabatı göndərildikdən sonra, xahiş edirik,\n"
"avtomatik açılan veb brauzerdə formanı doldurun."

#: ../bin/apport-cli.py:222
#, python-format
msgid "&Send report (%s)"
msgstr "Hesabatı &göndər (%s)"

#: ../bin/apport-cli.py:226
msgid "&Examine locally"
msgstr "Yerli olaraq &yoxla"

#: ../bin/apport-cli.py:230
msgid "&View report"
msgstr "Hesabata &bax"

#: ../bin/apport-cli.py:232
msgid "&Keep report file for sending later or copying to somewhere else"
msgstr ""
"Hesabat faylını daha sonra göndərmək və ya başqa yerə kopyalamaq üçün &saxla"

#: ../bin/apport-cli.py:235
msgid "Cancel and &ignore future crashes of this program version"
msgstr "Ləğv et və bu proqram versiyasının gələcək qəzalarını &görməzdən gəl"

#: ../bin/apport-cli.py:238 ../bin/apport-cli.py:318 ../bin/apport-cli.py:354
#: ../bin/apport-cli.py:375
msgid "&Cancel"
msgstr "&Ləğv et"

#: ../bin/apport-cli.py:259
msgid "Problem report file:"
msgstr "Problem hesabatı faylı:"

#: ../bin/apport-cli.py:265 ../bin/apport-cli.py:270
msgid "&Confirm"
msgstr "&Təsdiqlə"

#: ../bin/apport-cli.py:269
#, python-format
msgid "Error: %s"
msgstr "Xəta: %s"

#: ../bin/apport-cli.py:275 ../kde/apport-kde.py:470
msgid "Collecting problem information"
msgstr "Problem məlumatı toplanır"

#: ../bin/apport-cli.py:277
msgid ""
"The collected information can be sent to the developers to improve the\n"
"application. This might take a few minutes."
msgstr ""
"Toplanmış məlumat tətbiqi təkmilləşdirmək üçün inkişafçılara\n"
"göndərilə bilər. Bu, bir neçə dəqiqə çəkə bilər."

#: ../bin/apport-cli.py:293 ../gtk/apport-gtk.ui.h:17 ../kde/apport-kde.py:521
msgid "Uploading problem information"
msgstr "Problem məlumatı yüklənir"

#: ../bin/apport-cli.py:295
msgid ""
"The collected information is being sent to the bug tracking system.\n"
"This might take a few minutes."
msgstr ""
"Toplanmış məlumat xəta izləmə sisteminə göndərilir.\n"
"Bu, bir neçə dəqiqə çəkə bilər."

#: ../bin/apport-cli.py:316
msgid "&Yes"
msgstr "&Bəli"

#: ../bin/apport-cli.py:317
msgid "&No"
msgstr "&Xeyr"

