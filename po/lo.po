msgstr "<big><b>ຂໍອະໄພ, ເກີດຂໍ້ຜິດພາດພາຍໃນຂຶ້ນ.</b></big>"

#: ../gtk/apport-gtk.ui.h:8
msgid "Remember this in future"
msgstr "ຈື່ສິ່ງນີ້ໄວ້ໃນອະນາຄົດ"

#: ../gtk/apport-gtk.ui.h:9
